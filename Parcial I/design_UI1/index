<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Interfaz 1.1</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Playfair+Display:wght@700&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="style.css">
</head>
<body>

  <div class="card">

    <!-- Barra superior azul (navbar) -->
    <div class="navbar"></div>

    <!-- Grilla 3×3 -->
    <div class="grid">

      <!-- Fila 1 -->
      <div class="celda c1">
        <span class="label">background</span>
      </div>

      <div class="celda c2">
        <span class="label">rotate(45deg)</span>
        <div class="diamante"></div>
      </div>

      <div class="celda c3">
        <span class="label">background</span>
      </div>

      <!-- Fila 2 -->
      <div class="celda c4">
        <span class="label">padding + border</span>
        <div class="cuadro-interior"></div>
      </div>

      <div class="celda c5">
        <span class="label">border-radius:50%</span>
        <div class="circulo"></div>
      </div>

      <div class="celda c6">
        <span class="label">border-radius:50%</span>
        <div class="circulo-naranja"></div>
      </div>

      <!-- Fila 3 -->
      <div class="celda c7">
        <span class="label">flex-col + gap</span>
        <div class="barra b1"></div>
        <div class="barra b2"></div>
        <div class="barra b3"></div>
        <div class="barra b4"></div>
      </div>

      <div class="celda c8">
        <span class="label">padding + border</span>
        <div class="rect-interior"></div>
      </div>

      <div class="celda c9">
        <span class="label">padding + border</span>
        <div class="cuadro-verde-int"></div>
      </div>

    </div>

    <div class="footer">HTML5 + CSS3 · grid · flexbox</div>
  </div>

</body>
</html>